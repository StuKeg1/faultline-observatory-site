{
  "name": "faultline-observatory",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "validate:events": "node scripts/validate-events.js",
    "validate:mutations": "node scripts/validate-mutations.js",
    "validate:all": "npm run validate:events && npm run validate:mutations",
    "generate:redirects": "node scripts/generate-redirects.js",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "prebuild": "npm run validate:all && npm run generate:redirects && npm run generate:sitemap",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node --test src/data/recordDirectory.test.js src/pages/evidenceTrajectoryLayout.test.js src/pages/publicRecordPreview.test.js src/pages/homeQuestions.test.js scripts/redirects.test.js scripts/sitemap.test.js",
    "smoke:live": "node scripts/smoke-live.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
